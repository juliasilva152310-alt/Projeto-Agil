import time
import threading

# Classe para monitorar o trabalho de um colaborador
class MonitorTrabalho:
    def __init__(self, nome):
        self.nome = nome
        self.ativo = False
        self.tempo_total = 0

    def iniciar(self):
        self.ativo = True
        print(f"{self.nome} iniciou o trabalho.")
        inicio = time.time()
        while self.ativo:
            time.sleep(1)  # simula monitoramento em tempo real
            self.tempo_total = time.time() - inicio

    def parar(self):
        self.ativo = False
        print(f"{self.nome} parou. Tempo total: {self.tempo_total:.2f} segundos.")

# Função para rodar o monitor em paralelo
def monitorar_usuario(nome):
    usuario = MonitorTrabalho(nome)
    thread = threading.Thread(target=usuario.iniciar)
    thread.start()
    return usuario

# Exemplo de uso
if __name__ == "__main__":
    # Inicia monitoramento de dois colaboradores
    joao = monitorar_usuario("João")
    maria = monitorar_usuario("Maria")

    # Simula tempo de trabalho
    time.sleep(5)
    joao.parar()

    time.sleep(3)
    maria.parar()
